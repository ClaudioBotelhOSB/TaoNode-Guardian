# ─── TaoNode Guardian — OVH Public Cloud Terraform Variables ──────────────────
# Copy this file to terraform.tfvars and fill in the values.
# DO NOT commit this file with real token values.
# Add to .gitignore: terraform.tfvars  (or use *.tfvars)
#
# OVH provider credentials are read from environment variables:
#   export OVH_APPLICATION_KEY="your_app_key"
#   export OVH_APPLICATION_SECRET="your_app_secret"
#   export OVH_CONSUMER_KEY="your_consumer_key"
#
# OpenStack credentials are read from environment variables (source openrc.sh):
#   export OS_AUTH_URL="https://auth.cloud.ovh.net/v3"
#   export OS_PROJECT_ID="your_project_id"
#   export OS_USERNAME="your_username"
#   export OS_PASSWORD="your_password"
#   export OS_REGION_NAME="GRA11"

ovh_endpoint         = "ovh-eu"
openstack_auth_url   = "https://auth.cloud.ovh.net/v3"
openstack_region     = "GRA11"
openstack_project_id = "00000000-0000-0000-0000-000000000000"   # OVH Manager > Public Cloud > Project Settings

ssh_public_key = "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIMw7TPY4xostLb4DwenoTPH5fV+MsBJW6XiVRYaPTnXt taonode-demo"
flavor_name    = "b3-16"    # 4 vCPU / 16 GB RAM — equivalent to AWS t3.xlarge

# Aberto para todos (demo publico — compartilhavel com o time):
admin_cidrs = ["0.0.0.0/0"]
# Restrito ao seu IP (producao/staging):
# admin_cidrs = ["203.0.113.10/32"]   # curl -s https://checkip.amazonaws.com

# GitHub PAT — 'Contents: Read' scope — for cloning the repo during bootstrap.
# github_token = "github_pat_..."

# GitHub PAT — 'read:packages' scope — for pulling the container image from ghcr.io.
# Required to create the imagePullSecret 'ghcr-login-secret' in taonode-guardian-system.
# ghcr_pat = "github_pat_..."
