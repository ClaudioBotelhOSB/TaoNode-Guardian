  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 10,
      "title": "Chain Analytics",
      "type": "row"
    },
    {
      "datasource": "Clickhouse",
      "description": "Block Lag and Peer Count unified on a single timeline. Correlation between peer drop and lag spike is the key signal.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "fillOpacity": 8,
            "gradientMode": "none",
            "hideFrom": {"legend": false, "tooltip": false, "viz": false},
            "lineWidth": 2,
            "spanNulls": false
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "block_lag"},
            "properties": [
              {"id": "displayName", "value": "Block Lag"},
              {"id": "unit", "value": "short"},
              {"id": "color", "value": {"fixedColor": "red", "mode": "fixed"}},
              {"id": "custom.fillOpacity", "value": 15},
              {"id": "thresholds", "value": {
                "mode": "absolute",
                "steps": [
                  {"color": "green",  "value": null},
                  {"color": "orange", "value": 100},
                  {"color": "red",    "value": 500}
                ]
              }},
              {"id": "custom.thresholdsStyle", "value": {"mode": "line+area"}}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "peer_count"},
            "properties": [
              {"id": "displayName", "value": "Peer Count"},
              {"id": "unit", "value": "short"},
              {"id": "color", "value": {"fixedColor": "blue", "mode": "fixed"}},
              {"id": "custom.axisPlacement", "value": "right"}
            ]
          }
        ]
      },
      "gridPos": {"h": 12, "w": 24, "x": 0, "y": 1},
      "id": 1,
      "options": {
        "legend": {"calcs": ["mean", "max", "lastNotNull"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "datasource": "Clickhouse",
          "format": 1,
          "queryType": "sql",
          "rawSql": "SELECT\n  timestamp AS time,\n  block_lag,\n  peer_count\nFROM taonode_guardian.chain_telemetry\nWHERE $__timeFilter(timestamp)\nORDER BY timestamp ASC\nLIMIT 500",
          "refId": "A"
        }
      ],
      "title": "Block Lag vs Peer Count (Correlated)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
