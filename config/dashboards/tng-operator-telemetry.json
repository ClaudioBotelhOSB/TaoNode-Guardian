{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Guardian Kubernetes Operator internals — Reconcile loop latency and auto-recovery events.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 10,
      "title": "Operator Health",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "description": "Total auto-recovery actions triggered. Rapid growth indicates instability.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green",  "value": null},
              {"color": "yellow", "value": 5},
              {"color": "red",    "value": 20}
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 1},
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(taonode_guardian_auto_recovery_total)",
          "legendFormat": "Total Recoveries",
          "refId": "A"
        }
      ],
      "title": "Auto-Recovery Total",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "description": "Auto-recovery event rate per second.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red",   "value": 0.01}
            ]
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {"h": 5, "w": 6, "x": 6, "y": 1},
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(taonode_guardian_auto_recovery_total[$__rate_interval]))",
          "legendFormat": "Rate/s",
          "refId": "A"
        }
      ],
      "title": "Auto-Recovery Rate",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "description": "P99 reconcile loop duration.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green",  "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red",    "value": 5}
            ]
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {"h": 5, "w": 6, "x": 12, "y": 1},
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.99, sum(rate(taonode_guardian_reconcile_duration_seconds_bucket[$__rate_interval])) by (le))",
          "legendFormat": "P99",
          "refId": "A"
        }
      ],
      "title": "Reconcile P99 Latency",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "description": "P50 reconcile loop duration.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green",  "value": null},
              {"color": "yellow", "value": 0.5},
              {"color": "red",    "value": 2}
            ]
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {"h": 5, "w": 6, "x": 18, "y": 1},
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.50, sum(rate(taonode_guardian_reconcile_duration_seconds_bucket[$__rate_interval])) by (le))",
          "legendFormat": "P50",
          "refId": "A"
        }
      ],
      "title": "Reconcile P50 Latency",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 6},
      "id": 11,
      "title": "Reconcile Loop Detail",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "description": "Reconcile loop duration percentiles over time. Sustained high P99 = operator backpressure.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "fillOpacity": 10,
            "gradientMode": "none",
            "hideFrom": {"legend": false, "tooltip": false, "viz": false},
            "lineWidth": 2,
            "spanNulls": false,
            "thresholdsStyle": {"mode": "line"}
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green",  "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red",    "value": 5}
            ]
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 7},
      "id": 5,
      "options": {
        "legend": {"calcs": ["mean", "max", "lastNotNull"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.50, sum(rate(taonode_guardian_reconcile_duration_seconds_bucket[$__rate_interval])) by (le))",
          "legendFormat": "P50",
          "refId": "A"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, sum(rate(taonode_guardian_reconcile_duration_seconds_bucket[$__rate_interval])) by (le))",
          "legendFormat": "P95",
          "refId": "B"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.99, sum(rate(taonode_guardian_reconcile_duration_seconds_bucket[$__rate_interval])) by (le))",
          "legendFormat": "P99",
          "refId": "C"
        }
      ],
      "title": "Reconcile Duration P50 / P95 / P99",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "description": "Cumulative auto-recovery events over time. Steps indicate recovery actions taken.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "fillOpacity": 20,
            "gradientMode": "opacity",
            "hideFrom": {"legend": false, "tooltip": false, "viz": false},
            "lineWidth": 2,
            "spanNulls": false
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 17},
      "id": 6,
      "options": {
        "legend": {"calcs": ["lastNotNull", "sum"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "increase(taonode_guardian_auto_recovery_total[$__rate_interval])",
          "legendFormat": "{{node_name}} — {{reason}}",
          "refId": "A"
        }
      ],
      "title": "Auto-Recovery Events (increase over interval)",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["taonode-guardian", "operator", "telemetry", "prometheus"],
  "templating": {"list": []},
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "Guardian Operator Telemetry",
  "uid": "tng-operator-telemetry",
  "version": 1
}
